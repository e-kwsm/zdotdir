  '(- *)-disabled[List of disabled features]'
  '(- *)-options[List options for specified command]:val'
  '(- *)-objects[List built in objects (OID<->name mappings)]'


)
_arguments "${(@)args}"
}

(( $+functions[_openssl-rand] )) || _openssl-rand() {
typeset -ar args=(
  '(- *)-help[]'
  -out'[Output file]:outfile:_files'
  '(-hex)-base64[Base64 encode output]'
  '(-base64)-hex[Hex encode output]'
  '1:num'
)
_arguments "${(@)args}"
}

