#compdef openssl

_openssl() {
  typeset curcontext=$curcontext state lstate line
  local -ar args=(
    '(- *)'-help'[Provides a terse summary of all options]'
    '(- *)'-version'[Provides a terse summary of the openssl program version]'
    '*::openssl command:_openssl_command'
  )
  _arguments "${(@)args}"
}

